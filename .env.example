# PostgreSQL / Supabase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=change-me-to-a-random-secret
REFRESH_TOKEN_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# App
PORT=4000
FRONTEND_URL=http://localhost:5174

# Frontend (Vite) — only needed in production; dev uses the built-in Vite proxy
# VITE_API_BASE_URL=https://your-backend.example.com/api

# Notifications
WHATSAPP_API_URL=https://your-whatsapp-api.example.com
WHATSAPP_API_KEY=your-whatsapp-token
SMS_API_URL=https://your-sms-gateway.example.com
SMS_API_KEY=your-sms-token
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@example.com
EMAIL_SMTP_PASS=your-app-password
